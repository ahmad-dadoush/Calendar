{% apply spaceless %}

{% if app.user %}
    {% set currentRoute = app.request.attributes.get('_route') %}
    {% set navItems = [
        { route: 'app_home', label: 'Home' },
        { route: 'app_calendar', label: 'Kalendar' },
        { route: 'app_reminder', label: 'Erinnerungen' }
    ] %}

    <nav aria-label="Hauptnavigation" class="app-nav">
        <ul class="app-nav-list">
            {% for item in navItems %}
                <li{% if currentRoute == item.route %} class="is-active"{% endif %}>
                    <a href="{{ path(item.route) }}">{{ item.label }}</a>
                </li>
            {% endfor %}
            <li>
                <form method="post" action="{{ path('app_logout') }}" data-turbo="false" data-turbo-prefetch="false">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                    <button type="submit">Abmelden</button>
                </form>
            </li>
        </ul>
    </nav>
{% endif %}

{% endapply %}

